# Copy this file to .env and fill in what you need. Everything here is optional —
# Scribe runs fully free/local with no keys at all.

# ---- AI layer (summary + transcript cleanup) ----
# Provider: "none" (regex cleanup only), "ollama" (free, local), "anthropic", or "openai".
SCRIBE_LLM_PROVIDER=ollama

# Ollama (free, local). Default endpoint shown; pull a model first, e.g. `ollama pull llama3.1`.
SCRIBE_OLLAMA_HOST=http://localhost:11434
SCRIBE_OLLAMA_MODEL=llama3.1

# Anthropic (Claude). Only used when SCRIBE_LLM_PROVIDER=anthropic.
SCRIBE_ANTHROPIC_API_KEY=
SCRIBE_ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI. Only used when SCRIBE_LLM_PROVIDER=openai.
SCRIBE_OPENAI_API_KEY=
SCRIBE_OPENAI_MODEL=gpt-4o-mini

# ---- Transcription ----
# Whisper model size: tiny | base | small | medium | large-v3
# Bigger = more accurate, slower. "base" is a good CPU default.
SCRIBE_WHISPER_MODEL=base

# ---- Diarization (optional speaker labels) ----
# Requires `pip install pyannote.audio` and a free token from https://hf.co/settings/tokens
# (accept the pyannote/speaker-diarization-3.1 model terms on HuggingFace first).
SCRIBE_HF_TOKEN=
